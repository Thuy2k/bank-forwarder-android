<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TGS Bank Forwarder"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Telegram Bot Token" />

        <EditText
            android:id="@+id/etChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Telegram Chat ID" />

        <EditText
            android:id="@+id/etPrefix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Prefix (vd: TGS)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="Multi-shop mappings (uu tien: PREFIX|WEBHOOK_URL, cu: PREFIX|BOT_TOKEN|CHAT_ID)" />

        <EditText
            android:id="@+id/etShopMappings"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:gravity="top|start"
            android:hint="TGS|https://cuahangdemo.quantri.thegioisua.com/wp-json/ttck/v1/telegram-webhook?token=TGS_WEBHOOK_2026&#10;ABC|https://shop2.quantri.thegioisua.com/wp-json/ttck/v1/telegram-webhook?token=SECRET2"
            android:inputType="textMultiLine"
            android:scrollbars="vertical" />

        <EditText
            android:id="@+id/etSmsSenderFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SMS sender filter (optional)" />

        <EditText
            android:id="@+id/etPackageFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bank package filter, vd: mbbank,vcb" />

        <CheckBox
            android:id="@+id/cbSms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bat doc SMS" />

        <CheckBox
            android:id="@+id/cbNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bat doc Notification" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Luu cau hinh" />

        <Button
            android:id="@+id/btnOpenNotiAccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mo quyen Notification Access" />

        <Button
            android:id="@+id/btnOpenSmsPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xin quyen SMS" />

        <Button
            android:id="@+id/btnDisableBatteryOpt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tat toi uu pin cho app" />

        <Button
            android:id="@+id/btnTestSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gui test Telegram" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="Trang thai: Chua test" />

    </LinearLayout>

</ScrollView>
